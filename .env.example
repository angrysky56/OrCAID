# ============================================================
# OrCAID — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real keys.
# ============================================================

# ---- LLM (Manager agent) ------------------------------------
# Provider prefix + model name understood by LiteLLM.
# Examples:
#   MiniMax:   minimax/MiniMax-M2.1
#   OpenAI:    openai/gpt-4o
#   Anthropic: anthropic/claude-opus-4-5
LLM_MODEL=minimax/MiniMax-M2.1

# API key for the manager model.
LLM_API_KEY=your-minimax-api-key-here

# Base URL for the manager model API.
# MiniMax OpenAI-compat endpoint:
LLM_BASE_URL=https://api.minimax.io/v1
# MiniMax Anthropic-compat endpoint (for thinking/reasoning_split):
# LLM_BASE_URL=https://api.minimax.io/anthropic/v1/messages

# ---- LLM (Subagent — optional, falls back to LLM_MODEL) ------
# LLM_SUBAGENT_MODEL=minimax/MiniMax-M2.1-lightning
# LLM_SUBAGENT_API_KEY=your-subagent-key-here
# LLM_SUBAGENT_BASE_URL=https://api.minimax.io/v1

# ---- MiniMax native env vars (used by LiteLLM auto-detection) -
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_API_BASE=https://api.minimax.io/v1

# ---- Docker / Workspace ---------------------------------------
# Override SDK source directory if not at ../software-agent-sdk
# SDK_SOURCE_DIR=/path/to/software-agent-sdk

# ---- Judge (PaperBench only) ----------------------------------
# Python interpreter used by the judge subprocess.
# Defaults to the same python running OrCAID.
# JUDGE_PYTHON=/home/ty/Repositories/ai_workspace/OrCAID/.venv/bin/python

# ---- Misc -----------------------------------------------------
# Uncomment to enable verbose LiteLLM logging:
# LITELLM_LOG=DEBUG
